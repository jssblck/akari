package web

// tokenCard is the hover/focus breakdown behind an inline token figure: the
// four-class split (in, out, cache read, cache write), an optional reasoning line, and the
// cost line. The caller supplies the surrounding .tok-cell wrapper and the visible headline
// figure; this renders only the card. The landing page's demo panel is its remaining
// server-rendered call site; the app's own token figures render in the React frontend.
//
// reasoning is the model's hidden-deliberation class, shown only when a slice carries it
// (codex and pi report it; Claude and the session/project rollups do not, and pass 0), so
// the line appears only where a real figure exists rather than reading a hardcoded zero.
templ tokenCard(total, in, out, cacheRead, cacheWrite, reasoning int64, cost float64) {
	<span class="tok-tip" role="tooltip">
		<span class="tt-total">{ FmtTokens(total) } tokens</span>
		<dl class="tt-grid">
			<dt>In</dt>
			<dd>{ FmtTokens(in) }</dd>
			<dt>Out</dt>
			<dd>{ FmtTokens(out) }</dd>
			<dt>Cache read</dt>
			<dd>{ FmtTokens(cacheRead) }</dd>
			<dt>Cache write</dt>
			<dd>{ FmtTokens(cacheWrite) }</dd>
			if reasoning > 0 {
				<dt>Reasoning</dt>
				<dd>{ FmtTokens(reasoning) }</dd>
			}
		</dl>
		<span class="tt-cost">{ FmtCost(cost) }</span>
	</span>
}
