package web

import (
	"fmt"

	"github.com/jssblck/akari/internal/server/store"
)

templ SessionPage(p Page, d store.SessionDetail, msgs []store.Message, tools map[int][]store.ToolCallView, attachments map[int][]store.AttachmentView, subagents []store.SessionSummary, hs HeaderStats, dupIDs int, live, owner bool) {
	@layout(p) {
		<div class="session-page">
			<div class="session-head">
				<div class="session-title">
					<h1>
						<a href={ ProjectHref(d.ProjectID) }>{ SessionProjectLabel(d) }</a>
						<span class="sep">/</span>
						<span class="muted">session #{ fmt.Sprintf("%d", d.ID) }</span>
					</h1>
					if d.Title != "" {
						<div class="session-subtitle muted" title={ d.Title }>{ d.Title }</div>
					}
					<div class="session-meta">
						<span class="tag agent">{ d.Agent }</span>
						@kindTag(d.ProjectKind)
						if d.Visibility == "public" {
							<span class="tag public">public</span>
						}
						if dupIDs > 0 {
							<span class="tag warn" title="Repeated tool-call ids: a resumed or compacted transcript replaying earlier turns.">{ DuplicateIDsLabel(dupIDs) }</span>
						}
						if d.GitBranch != "" {
							<span class="muted">{ d.GitBranch }</span>
						}
						<span class="muted">{ d.Username }</span>
						<span class="muted">{ d.Machine }</span>
					</div>
				</div>
				if owner || p.IsAdmin {
					@sessionActions(d, owner)
				}
			</div>
			<div class="session-grid">
				<aside class="outline-rail" aria-label="Outline">
					@Outline(msgs, tools, SessionBlobBase(d.ID))
				</aside>
				if live {
					<div id="session-body" class="session-main" data-sse={ SSEPath(d.ID) } data-body={ BodyPath(d.ID) }>
						@SessionMain(d, msgs, tools, attachments, subagents, hs)
					</div>
				} else {
					<div id="session-body" class="session-main">
						@SessionMain(d, msgs, tools, attachments, subagents, hs)
					</div>
				}
			</div>
		</div>
		@inspectorModal()
	}
}

// sessionActions is the compact owner/admin control cluster pinned to the right
// of the session header: the publish state and its toggle for an owner, and the
// delete control for an owner or admin. It replaces the two full-width banners
// that used to sit under the header, so the controls cost one header line rather
// than two stacked rows.
templ sessionActions(d store.SessionDetail, owner bool) {
	<div class="session-actions">
		if owner {
			if d.Visibility == "public" && d.PublicID != nil {
				<a class="share-link muted small" href={ PublicHref(*d.PublicID) } title="Public share link">{ PublicPath(*d.PublicID) }</a>
				<form method="post" action={ templ.SafeURL(fmt.Sprintf("/sessions/%d/unpublish", d.ID)) } class="inline">
					<button class="secondary small" type="submit">Unpublish</button>
				</form>
			} else {
				<form method="post" action={ templ.SafeURL(fmt.Sprintf("/sessions/%d/publish", d.ID)) } class="inline">
					<button class="small" type="submit" title="Mint a public share link.">Publish</button>
				</form>
			}
		}
		<form method="post" action={ templ.SafeURL(fmt.Sprintf("/sessions/%d/delete", d.ID)) } class="inline" onsubmit="return confirm('Delete this session and its transcript permanently?')">
			<button class="danger small" type="submit" title="Deletes this session permanently.">Delete</button>
		</form>
	</div>
}

// SessionMain is the live region of the session view: the stat header, any
// subagents, and the transcript. Only this fragment is re-fetched and swapped on
// a live SSE update, so the outline and inspector (its siblings in the grid)
// persist across updates and are not re-rendered per refresh.
templ SessionMain(d store.SessionDetail, msgs []store.Message, tools map[int][]store.ToolCallView, attachments map[int][]store.AttachmentView, subagents []store.SessionSummary, hs HeaderStats) {
	@sessionStats(d, hs)
	if len(subagents) > 0 {
		<h2>Subagents</h2>
		<div class="subagents">
			@SessionList(subagents)
		</div>
	}
	<h2>Transcript</h2>
	@Transcript(msgs, d.Agent, tools, attachments, FallbacksByOrdinal(hs.Fallbacks), SessionBlobBase(d.ID))
}

// Outline is the left pane of the session view: one entry per turn, with its
// tool steps nested beneath. It renders straight from the transcript messages
// and tool metadata the page already holds, so no second session-sized structure
// is built. A turn links to its message; a step with a stored body opens that
// body in the inspector pane (carrying the blob URLs so the inspector needs no
// extra round trip to know what to fetch).
templ Outline(msgs []store.Message, tools map[int][]store.ToolCallView, blobBase string) {
	<div class="outline" aria-label="Session outline">
		<div class="label outline-head">Outline</div>
		for _, m := range msgs {
			{{ steps := tools[m.Ordinal] }}
			{{ title := OutlineTitle(m) }}
			<div class="ol-group">
				<a class={ OutlineTurnClass(m.Role, steps) } id={ fmt.Sprintf("ol-%d", m.Ordinal) } href={ templ.SafeURL(fmt.Sprintf("#msg-%d", m.Ordinal)) } data-ord={ fmt.Sprintf("%d", m.Ordinal) }>
					<span class="ol-dot"></span>
					<span class="ol-title">
						if title != "" {
							{ title }
						} else {
							<span class="ol-role">{ m.Role }</span>
						}
					</span>
					if len(steps) > 0 {
						<span class="ol-count">{ fmt.Sprintf("%d", len(steps)) }</span>
					}
				</a>
				if len(steps) > 0 {
					<div class="ol-steps">
						for _, s := range steps {
							if OutlineStepHasBody(s) {
								<a
									class={ OutlineStepClass(s) + " inspect-open" }
									href={ templ.SafeURL(fmt.Sprintf("#msg-%d", m.Ordinal)) }
									data-tool={ s.ToolName }
									data-file={ s.FilePath }
									data-status={ s.ResultStatus }
									if s.Detail != "" {
										data-detail={ s.Detail }
									}
									if DiffTool(s.ToolName) {
										data-diff="1"
									}
									if s.InputSHA != "" {
										data-input-url={ BlobURL(blobBase, s.InputSHA) }
									}
									if s.ResultSHA != "" {
										data-result-url={ BlobURL(blobBase, s.ResultSHA) }
									}
								>
									<span class="ol-tn">{ s.ToolName }</span>
									if p := ToolFilePath(s); p != "" {
										<span class="ol-file" title={ ToolFileTitle(s) }>{ BaseName(p) }</span>
									}
									if s.Detail != "" {
										<span class="ol-detail" title={ s.Detail }>{ DetailLabel(s.Detail) }</span>
									}
								</a>
							} else {
								<a class={ OutlineStepClass(s) } href={ templ.SafeURL(fmt.Sprintf("#msg-%d", m.Ordinal)) }>
									<span class="ol-tn">{ s.ToolName }</span>
									if s.Detail != "" {
										<span class="ol-detail" title={ s.Detail }>{ DetailLabel(s.Detail) }</span>
									}
								</a>
							}
						}
					</div>
				}
			</div>
		}
	</div>
}

// inspectorModal is the overlay host where a selected tool call's body opens as a
// large dialog, so reading a body never competes with the transcript for width.
// It starts hidden and empty; app.js fills #session-inspector and reveals the
// overlay when a tool chip or outline step is clicked, then clears it on close.
templ inspectorModal() {
	<div class="modal-overlay" id="session-modal" hidden>
		<div class="modal-dialog" id="session-inspector" role="dialog" aria-modal="true" aria-label="Tool call body"></div>
	</div>
}

// sessionStats is the instrument header: stat tiles that stick to the top of the
// transcript column and flash (needle-settle) when a live update changes a value. The
// Cache tile reads the session's own all-usage cache stats (dated or not), so its hit
// rate matches the token figures in the Tokens tile beside it; the Quality tile reads
// the session's stored signals.
templ sessionStats(d store.SessionDetail, hs HeaderStats) {
	<div class="stats sticky" id="session-stats">
		@stat("Messages", fmt.Sprintf("%d", d.MessageCount), "messages")
		@stat("User msgs", fmt.Sprintf("%d", d.UserMessageCount), "user")
		@tokenStat(d, hs.Signals)
		@statCache(hs.Cache)
		@statQuality(hs.Signals, hs.Thinking)
		if d.ModelFallbackCount > 0 {
			@statFallback(d.ModelFallbackCount, hs.Fallbacks)
		}
		@stat("Duration", FmtDuration(d.StartedAt, d.EndedAt), "dur")
	</div>
}

// statFallback is the model-fallback readout: it renders ONLY when the session had a
// fallback (a Claude Fable turn the safety classifier declined and re-served on a lower
// model), so its absence is the negative signal and the common session shows no tile. The
// count reads at a glance in the warn band; the per-fallback detail (the model pair, the
// refusal category, the declined attempt's token spend broken out by class, and the time)
// reveals on hover or keyboard focus through the same .stat-tip system the Quality and
// Tokens tiles use. A field the transcript never named reads a plain default (unknown,
// uncategorized) rather than a blank cell, since a single-line fallback can arrive with only
// part of its detail. The tooltip lists at most the first five fallbacks (the slice is
// already capped at the store read); a session that fell back more names the remainder in a
// closing "plus N more" line computed from the full count, so a pathological session's
// tooltip stays short.
templ statFallback(count int, fbs []store.ModelFallback) {
	<div class="stat fallback-stat" tabindex="0">
		<div class="label">Fallbacks</div>
		<div class="value fallback-value" data-stat-key="fallbacks">{ fmt.Sprintf("%d", count) }</div>
		<div class="stat-tip" role="tooltip">
			for i, f := range fbs {
				if i >= 5 {
					{{ break }}
				}
				if i > 0 {
					<div class="tt-sub">Fallback</div>
				}
				<dl class="tt-grid">
					<dt>Models</dt>
					<dd>{ FallbackModelsLabel(f) }</dd>
					<dt>Category</dt>
					<dd>{ FallbackCategoryLabel(f) }</dd>
					if FallbackDeclinedObserved(f) {
						// The four token classes, each on its own row rather than one summed figure, so a
						// reader sees the breakdown the way the Tokens tile shows it. A declined attempt is
						// never priced (it was refused, not served), so there is no cost line to pair with them.
						<dt>Declined input</dt>
						<dd>{ FmtTokens(*f.DeclinedInput) }</dd>
						<dt>Declined output</dt>
						<dd>{ FmtTokens(*f.DeclinedOutput) }</dd>
						<dt>Declined cache write</dt>
						<dd>{ FmtTokens(*f.DeclinedCacheWrite) }</dd>
						<dt>Declined cache read</dt>
						<dd>{ FmtTokens(*f.DeclinedCacheRead) }</dd>
					}
					<dt>Time</dt>
					<dd>{ FallbackTimeLabel(ctx, f) }</dd>
				</dl>
			}
			if over := FallbacksOverflow(count, min(len(fbs), 5)); over > 0 {
				<div class="tt-note">{ fmt.Sprintf("plus %d more", over) }</div>
			}
		</div>
	</div>
}

// statQuality is the session-quality readout: the letter grade reads at a glance,
// colour-banded like a report card, with the outcome, its confidence, the 0-100 score,
// and the tool-health counts that drove the score revealed on hover or keyboard focus,
// through the same tooltip system the Tokens and Cache tiles use. An unscored session
// (an unknown outcome with no tool signal) shows a neutral dash and names the outcome
// in the tooltip rather than inventing a grade. The tool-health rows are omitted for a
// pure-conversation session that ran no tools, so the tooltip shows only what applies.
// A separate Input group lists the prompt-hygiene signals that fired (terse, repeated, or
// no-code-context prompts, an unstructured opening); it reads the human's side and does
// not feed the score, so it sits under its own ruled label rather than among the drivers.
// A Thinking group reads the model's observed deliberation: the absolute band on the
// estimated-token scale and the per-turn volumes behind it (the hard-turn mean the band
// reads, the single hardest turn, and how many turns reasoned). Like Input it never feeds
// the score; how hard the model had to think is workload, not fault.
templ statQuality(s store.SessionSignals, t ThinkingReadout) {
	<div class={ "stat quality-stat " + QualityGradeClass(s) } tabindex="0">
		<div class="label">Quality</div>
		<div class="value quality-value" data-stat-key="quality">{ QualityGrade(s) }</div>
		<div class="stat-tip" role="tooltip">
			<dl class="tt-grid">
				<dt>Outcome</dt>
				<dd>{ OutcomeLabel(s.Outcome) }</dd>
				<dt>Confidence</dt>
				<dd>{ s.OutcomeConfidence }</dd>
				<dt>Score</dt>
				<dd>{ QualityScoreLabel(s) }</dd>
				if s.HasToolActivity() {
					<dt>Failures</dt>
					<dd>{ fmt.Sprintf("%d / %d", s.ToolFailures, s.ToolCalls) }</dd>
					<dt>Retries</dt>
					<dd>{ fmt.Sprintf("%d", s.ToolRetries) }</dd>
					<dt>Edit churn</dt>
					<dd>{ fmt.Sprintf("%d", s.EditChurn) }</dd>
					<dt>Longest fail streak</dt>
					<dd>{ fmt.Sprintf("%d", s.LongestFailureStreak) }</dd>
				}
			</dl>
			if s.HasHygieneSignal() {
				<div class="tt-sub">Input</div>
				<dl class="tt-grid">
					if s.ShortPromptCount > 0 {
						<dt>Terse prompts</dt>
						<dd>{ fmt.Sprintf("%d", s.ShortPromptCount) }</dd>
					}
					if s.DuplicatePromptCount > 0 {
						<dt>Repeated</dt>
						<dd>{ fmt.Sprintf("%d", s.DuplicatePromptCount) }</dd>
					}
					if s.NoCodeContextCount > 0 {
						<dt>No code pointer</dt>
						<dd>{ fmt.Sprintf("%d", s.NoCodeContextCount) }</dd>
					}
					if s.UnstructuredStart {
						<dt>Opening</dt>
						<dd>terse</dd>
					}
				</dl>
			}
			if t.Measured {
				<div class="tt-sub">Thinking</div>
				<dl class="tt-grid">
					<dt>Observed</dt>
					<dd>{ ThinkingBucketLabel(t.Bucket) }</dd>
					if t.Turns > 0 {
						<dt>Hard-turn mean</dt>
						<dd>{ ThinkingTokensLabel(t.TailTokens) }</dd>
						<dt>Hardest turn</dt>
						<dd>{ ThinkingTokensLabel(t.PeakTokens) }</dd>
						<dt>Reasoned</dt>
						<dd>{ fmt.Sprintf("%d of %d turns", t.Turns, *s.AssistantTurns) }</dd>
					}
				</dl>
				<div class="tt-note muted small">Observed deliberation on an absolute token scale: how hard the model actually thought, not a configured level. Per-turn tokens are exact where the agent reports them, else estimated from the reasoning trace.</div>
			}
			if s.Scored() {
				// The score arithmetic explains the grade rather than asserting it: one row per
				// penalty (label left, the negative points it subtracted right), then the final
				// score. A clean scored run has no penalties, so it reads "no penalties" instead of
				// an empty group.
				{{ breakdown := ScoreBreakdownItems(s) }}
				<div class="tt-sub">Score arithmetic</div>
				<dl class="tt-grid tt-score">
					if len(breakdown) == 0 {
						<dt>No penalties</dt>
						<dd class="mono">-0</dd>
					} else {
						for _, item := range breakdown {
							<dt>{ item.Label }</dt>
							<dd class="mono">{ fmt.Sprintf("-%d", item.Points) }</dd>
						}
					}
					<dt>Score</dt>
					<dd class="mono">{ fmt.Sprintf("%d", *s.Score) }</dd>
				</dl>
			}
		</div>
	</div>
}

// tokenStat folds the five token-and-cost readouts (input, output, cache read,
// cache write, cost) into one Tokens tile: the total reads at a glance, and the
// per-class breakdown plus cost reveal on hover or keyboard focus, the same detail
// the overview heatmap surfaces for a day. When the session's context was measured, a
// Context sub-group adds the heaviest single-turn context it held and how many times it
// shed that context (a compaction or clear), token-flavored facts that sit naturally
// beside the token totals but describe peak load rather than cumulative spend. Peak
// context is one occupancy figure (a single turn's input plus cache read plus cache
// write, output excluded), not a general tokens total, so instead of the four-class
// spend breakdown card it carries a plain caption of what it is made of: there is no
// per-class total to break down. This is the deliberate single-metric exemption the
// token-consistency convention allows, not a dropped class.
templ tokenStat(d store.SessionDetail, s store.SessionSignals) {
	<div class="stat tokens-stat" tabindex="0">
		<div class="label">Tokens</div>
		<div class="value tokens-value" data-stat-key="tokens">{ FmtTokens(d.TotalInput + d.TotalOutput + d.TotalCacheRead + d.TotalCacheWrite) }</div>
		<div class="stat-tip" role="tooltip">
			<dl class="tt-grid">
				<dt>Input</dt>
				<dd>{ FmtTokens(d.TotalInput) }</dd>
				<dt>Output</dt>
				<dd>{ FmtTokens(d.TotalOutput) }</dd>
				<dt>Cache read</dt>
				<dd>{ FmtTokens(d.TotalCacheRead) }</dd>
				<dt>Cache write</dt>
				<dd>{ FmtTokens(d.TotalCacheWrite) }</dd>
			</dl>
			if s.HasContextHealth() {
				<div class="tt-sub">Context</div>
				<dl class="tt-grid">
					<dt>Peak context</dt>
					<dd>{ PeakContextLabel(s) }</dd>
					<dt>Resets</dt>
					<dd>{ ContextResetsLabel(s) }</dd>
				</dl>
				<div class="tt-note muted small">Peak is the heaviest single turn's prompt: input, cache read, and cache write, output excluded. It measures context load, not spend.</div>
			}
			<div class="tt-cost">{ FmtCost(d.TotalCostUSD, d.CostIncomplete) }</div>
		</div>
	</div>
}

templ stat(label, value, key string) {
	<div class="stat">
		<div class="label">{ label }</div>
		if key != "" {
			<div class="value" data-stat-key={ key }>{ value }</div>
		} else {
			<div class="value">{ value }</div>
		}
	</div>
}

// Transcript renders the session's messages as an instrumented trace. The two carried per-message
// instruments (reply latency and context sheds) are derived while walking the message slice with a
// TranscriptWalker holding only bounded state (see session_metrics.go), so the render path holds no
// session-sized structure beyond the message slice the page already renders; the duplicate-prompt
// verdict rides on each message (m.DuplicatePrompt), and each turn's usage rides on m.Usage, both
// folded in the message read. The meta line carries a right-aligned cluster of stamps (latency,
// then a context+cost stamp group that hosts a per-turn token breakdown card); a shed divider
// hosting its own before/after breakdown card is drawn above the marked message; muted hygiene tags
// sit after a user message's role tag. An assistant turn that carried a reasoning block wears a thinking-band chip
// above its content (MessageThinkingBand), reading the turn's own deliberation on the same absolute scale as the
// header readout, so a reader sees which turns the model worked hardest on without opening the (often redacted) trace.
templ Transcript(msgs []store.Message, agent string, tools map[int][]store.ToolCallView, attachments map[int][]store.AttachmentView, fallbacks map[int]store.ModelFallback, blobBase string) {
	if len(msgs) == 0 {
		<div class="empty">No messages parsed yet.</div>
	} else {
		{{ walker := &TranscriptWalker{} }}
		<div class="transcript">
			for _, m := range msgs {
				{{ metrics := walker.Next(m) }}
				if metrics.Shed != nil {
					@shedDivider(*metrics.Shed)
				}
				if fb, ok := fallbacks[m.Ordinal]; ok {
					@fallbackNotice(fb)
				}
				if m.Role == "context" {
					@contextTurn(m)
				} else {
				<div class={ "msg " + RoleClass(m.Role) } id={ fmt.Sprintf("msg-%d", m.Ordinal) } data-ordinal={ fmt.Sprintf("%d", m.Ordinal) }>
					<div class="meta">
						<span class="role">{ m.Role }</span>
						if m.Model != "" {
							<span class="tag model">{ m.Model }</span>
						}
						if m.Role == "user" && m.PromptFactsCurrent {
							if m.PromptShort {
								<span class="tag hygiene" title="under 4 words: give the agent something to grip">terse</span>
							}
							if m.PromptNoCode {
								<span class="tag hygiene" title="a change request with no file, path, or code anchor">no code pointer</span>
							}
							if m.DuplicatePrompt {
								<span class="tag hygiene" title="verbatim repeat of an earlier prompt">repeat</span>
							}
						}
						<span class="spacer"></span>
						<span class="meta-metrics">
							if metrics.Latency > 0 {
								<span class="stamp-latency mono" title="time from the prompt to this reply">{ FmtTurnLatency(metrics.Latency) }</span>
							}
							if m.Usage != nil {
								// One focusable host wraps the ctx and cost stamps and carries a single
								// per-turn breakdown card (the four token classes, reasoning if present, the
								// context total, and the turn cost or "unpriced"). The visible stamps stay as
								// compact as before; the card is the detail, so no bare token figure renders
								// without its breakdown.
								<span class="tok-cell turn-metrics" tabindex="0">
									<span class="stamp-ctx mono">{ FmtContextStamp(*m.Usage) }</span>
									if m.Usage.CostUSD != nil {
										<span class="stamp-cost mono">{ FmtCost(*m.Usage.CostUSD, m.Usage.CostIncomplete) }</span>
									}
									@turnCard(*m.Usage)
								</span>
							}
						</span>
						<span class="muted small">{ FmtTime(ctx, m.Timestamp) }</span>
					</div>
					if band, ok := MessageThinkingBand(agent, m); ok {
						<div class={ "thinking-band band-" + string(band) } title="observed deliberation on this turn, on an absolute token scale (exact where the agent reports it, else estimated from the reasoning trace)">
							<span class="thinking-band-dot"></span>
							<span class="thinking-band-label">thinking: { ThinkingBucketLabel(band) }</span>
						</div>
					}
					if m.HasThinking && m.ThinkingText != "" {
						<details class="thinking">
							<summary>Thinking</summary>
							<div class="thinking-body">{ m.ThinkingText }</div>
						</details>
					}
					if m.Content != "" {
						<div class="content">{ m.Content }</div>
					}
					if as := attachments[m.Ordinal]; len(as) > 0 {
						<div class="attachments">
							for _, a := range as {
								@AttachmentTile(a, blobBase)
							}
						</div>
					}
					if tc := tools[m.Ordinal]; len(tc) > 0 {
						<div class="tools">
							for _, t := range tc {
								@ToolChip(t, blobBase)
							}
						</div>
					}
				</div>
				}
			}
		</div>
	}
}

// contextTurn renders an injected-context message (agent framing: project
// instructions, the environment block) as a collapsed disclosure at its place in
// the transcript, so the session's real opening prompt reads first and the framing
// stays available but out of the way. It carries no reply latency, token load,
// tools, or hygiene tags: it is not a human turn, so none of those instruments
// apply. The id matches the outline's #msg-<ordinal> anchor so the Context outline
// row still scrolls to it.
templ contextTurn(m store.Message) {
	<details class="msg msg-context context-turn" id={ fmt.Sprintf("msg-%d", m.Ordinal) } data-ordinal={ fmt.Sprintf("%d", m.Ordinal) }>
		<summary class="context-summary">
			<span class="role">context</span>
			<span class="tag context-kind">{ ContextLabel(m.Content) }</span>
			<span class="spacer"></span>
			<span class="muted small">{ FmtTime(ctx, m.Timestamp) }</span>
		</summary>
		if m.Content != "" {
			<div class="content">{ m.Content }</div>
		}
	</details>
}

// shedDivider draws the context-shed divider above the turn that first ran on the shed-down
// context: the centered "context shed: <from> -> <to>" label, hosting a focusable breakdown card
// that splits the before turn and the after turn into their token classes and cost. The label's
// two figures are context occupancy (input + cache read + cache write), so each bare figure gets
// its full per-class detail in the card rather than standing alone, the same treatment every other
// token figure in the transcript carries. Each side carries its own cost line (the turn's cost, or
// "unpriced" when it never got a rate) through the same TurnCostLabel and .tt-cost idiom the turn
// card uses, so the two occupancy figures never render without the spend behind them. The divider
// is focusable (tabindex) so the card opens on keyboard focus as well as hover, matching the turn
// stamp beside it.
templ shedDivider(shed ShedMark) {
	<div class="msg-shed tok-cell" role="separator" tabindex="0" aria-label={ ShedLabel(shed) }>
		<span class="shed-label mono">{ ShedLabel(shed) }</span>
		<span class="tok-tip shed-tip" role="tooltip">
			<span class="tt-total">context shed</span>
			<dl class="tt-grid">
				<dt>Before</dt>
				<dd>{ FmtTokens(shed.FromTokens) }</dd>
				<dt>In</dt>
				<dd>{ FmtTokens(shed.FromUsage.Input) }</dd>
				<dt>Cache read</dt>
				<dd>{ FmtTokens(shed.FromUsage.CacheRead) }</dd>
				<dt>Cache write</dt>
				<dd>{ FmtTokens(shed.FromUsage.CacheWrite) }</dd>
				<dt>Output</dt>
				<dd>{ FmtTokens(shed.FromUsage.Output) }</dd>
			</dl>
			<span class="tt-cost">{ TurnCostLabel(shed.FromUsage) }</span>
			<dl class="tt-grid shed-after">
				<dt>After</dt>
				<dd>{ FmtTokens(shed.ToTokens) }</dd>
				<dt>In</dt>
				<dd>{ FmtTokens(shed.ToUsage.Input) }</dd>
				<dt>Cache read</dt>
				<dd>{ FmtTokens(shed.ToUsage.CacheRead) }</dd>
				<dt>Cache write</dt>
				<dd>{ FmtTokens(shed.ToUsage.CacheWrite) }</dd>
				<dt>Output</dt>
				<dd>{ FmtTokens(shed.ToUsage.Output) }</dd>
			</dl>
			<span class="tt-cost">{ TurnCostLabel(shed.ToUsage) }</span>
		</span>
	</div>
}

// fallbackNotice draws a slim, warn-styled row above the turn a model fallback landed on,
// naming the model pair and the trigger in one plain sentence. Detection is marker-based
// (an intentional model switch is never in this data), so the copy states "fell back"
// plainly rather than hedging. It keeps the shed divider's low-key styling in the warn hue,
// so the transcript reads it as an observability mark rather than a warning banner.
templ fallbackNotice(f store.ModelFallback) {
	<div class="msg-fallback" role="note">
		<span class="fallback-label">{ FallbackNoticeLabel(f) }</span>
	</div>
}

// AttachmentTile renders one binary attachment. An image is shown inline from its
// CAS blob (the same URL the inspector would fetch), captioned with its filename
// and size; a non-image is a labelled link so it can still be opened.
templ AttachmentTile(a store.AttachmentView, blobBase string) {
	if IsImageMedia(a.MediaType) {
		<figure class="attachment image">
			<a href={ BlobURL(blobBase, a.SHA256) } target="_blank" rel="noopener">
				<img src={ BlobURL(blobBase, a.SHA256) } alt={ AttachmentAlt(a) } loading="lazy"/>
			</a>
			<figcaption class="muted small">
				if a.Filename != "" {
					{ a.Filename + " · " }
				}
				{ ChipLabel(a.MediaType, a.ByteLen) }
			</figcaption>
		</figure>
	} else {
		<a class="attachment file stamp" href={ BlobURL(blobBase, a.SHA256) } target="_blank" rel="noopener">
			if a.Filename != "" {
				{ a.Filename + " · " }
			}
			{ ChipLabel(a.MediaType, a.ByteLen) }
		</a>
	}
}

// ToolChip renders one tool call's metadata. A body that lives in the CAS is a
// clickable chip carrying its blob URL plus the tool name and slot, so app.js can
// expand an editing tool's input as an inline diff rather than raw JSON.
templ ToolChip(t store.ToolCallView, blobBase string) {
	<div class="tool-chip">
		<span class="tname">{ t.ToolName }</span>
		if p := ToolFilePath(t); p != "" {
			<span class="tpath muted" title={ ToolFileTitle(t) }>{ p }</span>
		}
		if t.Detail != "" {
			<span class="tdetail muted" title={ t.Detail }>{ DetailLabel(t.Detail) }</span>
		}
		if t.InputSHA != "" {
			<button
				type="button"
				class="stamp body-toggle"
				data-blob-url={ BlobURL(blobBase, t.InputSHA) }
				data-tool={ t.ToolName }
				data-slot="input"
				if DiffTool(t.ToolName) {
					data-diff="1"
				}
			>in: { ChipLabel(t.InputMediaType, t.InputBytes) }</button>
		} else if t.InputBytes > 0 {
			<span class="stamp">in: { ChipLabel(t.InputMediaType, t.InputBytes) }</span>
		}
		if t.ResultStatus != "" {
			<span class={ "tstatus " + StatusClass(t.ResultStatus) }>{ t.ResultStatus }</span>
			if t.ResultSHA != "" {
				<button
					type="button"
					class="stamp body-toggle"
					data-blob-url={ BlobURL(blobBase, t.ResultSHA) }
					data-tool={ t.ToolName }
					data-slot="result"
				>out: { ChipLabel(t.ResultMediaType, t.ResultBytes) }</button>
			} else if t.ResultBytes > 0 {
				<span class="stamp">out: { ChipLabel(t.ResultMediaType, t.ResultBytes) }</span>
			}
		}
	</div>
}
