package web

import (
	"time"

	"github.com/jssblck/akari/internal/server/store"
)

// InsightsPage is the fleet-wide analytics surface at /insights: seven measurement
// instruments, each drawn client-side by static/js/insights.js from the trend grid the
// server embeds in #insights-data. The sections read the fleet as a set of time series
// over the selected window: the model mix, a per-session gallery, velocity, tools, health,
// economics, and subagent delegation. Every series shares one bucket grid (day or week,
// per the range), so the range control windows every chart together in one htmx swap of
// the #insights section.
//
// Unlike the project pages' compact quality band (quality_band.templ), this page owns its
// own chart engine and draws no server-side bars. The whole section carries id="insights"
// so the range selector can swap it in one shot, carrying the fresh data script with it;
// insights.js re-runs on htmx:afterSwap and redraws from the new payload.
templ InsightsPage(p Page, ins store.Insights, rng string, ranges []RangeOption, computedAt time.Time) {
	@layout(p) {
		<section id="insights">
			<div class="page">
				<header class="page-header">
					// The page serves from a snapshot recomputed on a cadence (up to an hour
					// old), not live data, so say when it was taken: a reader comparing these
					// figures against a live surface (the overview, the sessions feed) needs
					// the snapshot's age to explain the gap.
					if !computedAt.IsZero() {
						<span class="snapshot-age muted small" title={ FmtTimeLong(ctx, &computedAt) }>{ FmtSnapshotAge(computedAt) }</span>
					}
					@insightsRangeControl(ranges)
				</header>
				if ins.Trends == nil || !ins.Trends.HasData() {
					<div class="empty">No sessions in this window yet.</div>
				} else {
					@insightsInstruments()
					@insightsDataElement(ins)
				}
			</div>
			<div class="chart-tooltip" id="tooltip" role="status"></div>
		</section>
	}
}

// insightsRangeControl is the live trailing-window selector, styled as the concept's
// range-control: each button refetches and swaps the whole #insights section (data script
// included), so switching the window rewindows every instrument at once. The active window
// carries aria-current, which the stylesheet marks; the rest drive the htmx refetch.
templ insightsRangeControl(ranges []RangeOption) {
	<div class="range-control" role="group" aria-label="Date range">
		for _, o := range ranges {
			<button
				type="button"
				if o.Active {
					aria-current="true"
				}
				hx-get={ o.Href }
				hx-target="#insights"
				hx-select="#insights"
				hx-swap="outerHTML"
				hx-push-url="true"
			>{ o.Label }</button>
		}
	</div>
}

// instrumentCaption is one instrument's caption in two registers. The lead is the sentence a
// reader sees first: plain language, answering "what does this tell me" without a single
// column name. The demoted "How it's measured" disclosure carries the schema-level detail
// (the tables, the exact predicate, the caveats) for whoever wants it. Splitting the two is
// the approachability fix: the page reads as instruments a team lead can use, not as a tour
// of the schema, while the precise method stays one click away rather than deleted.
templ instrumentCaption(lead string) {
	<p class="panel-caption">{ lead }</p>
	<details class="panel-how">
		<summary>How it's measured</summary>
		<div class="panel-how-body">
			{ children... }
		</div>
	</details>
}

// insightsInstruments is the seven-section instrument panel: static scaffolding (headings,
// tab strips, chart mount points) that insights.js populates from AK_DATA. It carries no Go
// data of its own; every id here is a mount target the chart engine looks up by name, so the
// markup and the script share one contract.
templ insightsInstruments() {
	<!-- 1. Fleet mix -->
	<section class="instrument" id="fleetmix" aria-labelledby="fleetmix-h">
		<div class="instrument-head">
			<h2 id="fleetmix-h">Fleet mix</h2>
		</div>
		<div class="panel">
			<div class="figures-row" id="fleetmix-figures"></div>
			<div id="chart-fleetmix-full"></div>
			<ul class="legend" id="fleetmix-legend" style="margin-top:10px;"></ul>
			@instrumentCaption("Which models did the work, and how the mix shifted across the window.") {
				<code>usage_events.model</code> token share per bucket; a migration shows up here as one band growing while another shrinks, without reading release notes.
			}
		</div>
	</section>
	<!-- 2. Session gallery -->
	<section class="instrument" id="gallery" aria-labelledby="gallery-h">
		<div class="instrument-head">
			<h2 id="gallery-h">Session gallery</h2>
		</div>
		<div class="panel">
			<div class="figures-row" id="gallery-figures"></div>
			<div id="chart-gallery-full"></div>
			<div class="muted small" id="gallery-sample" style="margin-top:6px;"></div>
			<ul class="legend" id="gallery-legend" style="margin-top:10px;"></ul>
			@instrumentCaption("Every session as one dot, so the long or expensive outliers stop hiding inside the averages.") {
				Every fully spanned session is one dot, placed by how long it ran and what it cost, coloured by archetype.
			}
		</div>
	</section>
	<!-- 3. Velocity -->
	<section class="instrument" id="velocity" aria-labelledby="velocity-h">
		<div class="instrument-head">
			<h2 id="velocity-h">Velocity</h2>
		</div>
		<div class="panel">
			<div role="tablist" aria-label="Velocity instruments" class="tabstrip" id="velocity-tabs">
				<button role="tab" id="vtab-all" aria-controls="vpanel-all" aria-selected="true" tabindex="0">All instruments</button>
				<button role="tab" id="vtab-activehours" aria-controls="vpanel-activehours" aria-selected="false" tabindex="-1">Agent hours</button>
				<button role="tab" id="vtab-response" aria-controls="vpanel-response" aria-selected="false" tabindex="-1">Response time</button>
				<button role="tab" id="vtab-throughput" aria-controls="vpanel-throughput" aria-selected="false" tabindex="-1">Throughput</button>
				<button role="tab" id="vtab-rhythm" aria-controls="vpanel-rhythm" aria-selected="false" tabindex="-1">Rhythm</button>
			</div>
			<div class="tabpanel" id="vpanel-all" role="tabpanel" aria-labelledby="vtab-all" tabindex="0">
				<div class="grid-2x2">
					<button class="mini-multiple" data-jump="velocity-tabs:vtab-activehours" data-scroll="velocity" id="mini-activehours"></button>
					<button class="mini-multiple" data-jump="velocity-tabs:vtab-response" data-scroll="velocity" id="mini-response"></button>
					<button class="mini-multiple" data-jump="velocity-tabs:vtab-throughput" data-scroll="velocity" id="mini-throughput"></button>
					<button class="mini-multiple" data-jump="velocity-tabs:vtab-rhythm" data-scroll="velocity" id="mini-rhythm"></button>
				</div>
			</div>
			<div class="tabpanel instrument-solo" id="vpanel-activehours" role="tabpanel" aria-labelledby="vtab-activehours" tabindex="0" hidden>
				<div class="figures-row" id="activehours-figures"></div>
				<div id="chart-activehours-full"></div>
				@instrumentCaption("Hands-on agent time against wall-clock time; the gap between them is sessions left sitting open.") {
					Bars are hands-on agent time per bucket (gap time over the idle threshold removed); the dotted line is wall-clock session span, the same integral behind the concurrency figures.
				}
			</div>
			<div class="tabpanel instrument-solo" id="vpanel-response" role="tabpanel" aria-labelledby="vtab-response" tabindex="0" hidden>
				<div id="chart-response-full"></div>
				@instrumentCaption("How quickly the agent answers a prompt, and how long the slow tail runs.") {
					<code>messages.timestamp</code> deltas between a prompt and the agent's first reply: p50 line, p50 to p90 band, and a p99 line for the long tail.
				}
			</div>
			<div class="tabpanel instrument-solo" id="vpanel-throughput" role="tabpanel" aria-labelledby="vtab-throughput" tabindex="0" hidden>
				<div class="figures-row" id="throughput-figures"></div>
				<div id="chart-throughput-full"></div>
				@instrumentCaption("How much the agent gets through per active minute: messages and tool calls.") {
					Cadence per active minute over hands-on time. Output tokens per second would need a generation duration the projection does not record, so this reads the two densities we can derive honestly.
				}
			</div>
			<div class="tabpanel instrument-solo" id="vpanel-rhythm" role="tabpanel" aria-labelledby="vtab-rhythm" tabindex="0" hidden>
				<div class="overflow-x"><div id="chart-punchcard" style="min-width:480px;"></div></div>
				@instrumentCaption("When in the week the fleet is busiest.") {
					Cell brightness is message and tool volume by hour of week, joining <code>tool_calls</code> and <code>messages</code> to <code>messages.timestamp</code>.
				}
			</div>
		</div>
	</section>
	<!-- 4. Tools -->
	@toolsInstrument()
	<!-- 5. Health -->
	<section class="instrument" id="health" aria-labelledby="health-h">
		<div class="instrument-head">
			<h2 id="health-h">Health</h2>
		</div>
		<div class="panel">
			<div role="tablist" aria-label="Health instruments" class="tabstrip" id="health-tabs">
				<button role="tab" id="htab-all" aria-controls="hpanel-all" aria-selected="true" tabindex="0">All instruments</button>
				<button role="tab" id="htab-grades" aria-controls="hpanel-grades" aria-selected="false" tabindex="-1">Grades</button>
				<button role="tab" id="htab-outcomes" aria-controls="hpanel-outcomes" aria-selected="false" tabindex="-1">Outcomes</button>
				<button role="tab" id="htab-hygiene" aria-controls="hpanel-hygiene" aria-selected="false" tabindex="-1">Hygiene</button>
				<button role="tab" id="htab-context" aria-controls="hpanel-context" aria-selected="false" tabindex="-1">Context</button>
			</div>
			<div class="tabpanel" id="hpanel-all" role="tabpanel" aria-labelledby="htab-all" tabindex="0">
				<div class="grid-2x2">
					<button class="mini-multiple" data-jump="health-tabs:htab-grades" data-scroll="health" id="mini-grades"></button>
					<button class="mini-multiple" data-jump="health-tabs:htab-outcomes" data-scroll="health" id="mini-outcomes"></button>
					<button class="mini-multiple" data-jump="health-tabs:htab-hygiene" data-scroll="health" id="mini-hygiene"></button>
					<button class="mini-multiple" data-jump="health-tabs:htab-context" data-scroll="health" id="mini-context"></button>
				</div>
			</div>
			<div class="tabpanel instrument-solo" id="hpanel-grades" role="tabpanel" aria-labelledby="htab-grades" tabindex="0" hidden>
				<div id="chart-grades"></div>
				@instrumentCaption("How session quality graded over time.") {
					<code>session_signals.grade</code> re-read per bucket. The settle pass already stamps every session; this is the same column drawn over time instead of one rolled-up number.
				}
			</div>
			<div class="tabpanel instrument-solo" id="hpanel-outcomes" role="tabpanel" aria-labelledby="htab-outcomes" tabindex="0" hidden>
				<div id="chart-outcomes"></div>
				@instrumentCaption("How sessions ended over time: completed against abandoned.") {
					<code>session_signals.outcome</code> per bucket, with raw session counts underneath.
				}
			</div>
			<div class="tabpanel instrument-solo" id="hpanel-hygiene" role="tabpanel" aria-labelledby="htab-hygiene" tabindex="0" hidden>
				<div id="chart-hygiene"></div>
				<ul class="legend" id="hygiene-legend" style="margin-top:10px;"></ul>
				@instrumentCaption("How well-formed the prompts were over time: short, code-free, or repeated.") {
					<code>messages.prompt_facts</code> classified per prompt, rolled up per bucket as a share of the bucket's prompts touched by each flag.
				}
			</div>
			<div class="tabpanel instrument-solo" id="hpanel-context" role="tabpanel" aria-labelledby="htab-context" tabindex="0" hidden>
				<div id="chart-context"></div>
				@instrumentCaption("How close sessions ran to the model's context limit.") {
					Peak context tokens per session, banded on the absolute token scale, so a fleet crowding its context window reads before sessions start dropping work.
				}
			</div>
		</div>
	</section>
	<!-- 6. Economics -->
	<section class="instrument" id="economics" aria-labelledby="economics-h">
		<div class="instrument-head">
			<h2 id="economics-h">Economics</h2>
		</div>
		<div class="panel">
			<div role="tablist" aria-label="Economics instruments" class="tabstrip" id="economics-tabs">
				<button role="tab" id="etab-all" aria-controls="epanel-all" aria-selected="true" tabindex="0">All instruments</button>
				<button role="tab" id="etab-costquality" aria-controls="epanel-costquality" aria-selected="false" tabindex="-1">Cost of quality</button>
				<button role="tab" id="etab-cache" aria-controls="epanel-cache" aria-selected="false" tabindex="-1">Cache</button>
			</div>
			<div class="tabpanel" id="epanel-all" role="tabpanel" aria-labelledby="etab-all" tabindex="0">
				<div class="grid-2">
					<button class="mini-multiple" data-jump="economics-tabs:etab-costquality" data-scroll="economics" id="mini-costquality"></button>
					<button class="mini-multiple" data-jump="economics-tabs:etab-cache" data-scroll="economics" id="mini-cache"></button>
				</div>
			</div>
			<div class="tabpanel instrument-solo" id="epanel-costquality" role="tabpanel" aria-labelledby="etab-costquality" tabindex="0" hidden>
				<div class="figures-row" id="costquality-figures"></div>
				<div id="chart-costquality-full"></div>
				<ul class="legend" id="costquality-legend" style="margin-top:10px;"></ul>
				@instrumentCaption("How much spend went to work that completed against work that was abandoned.") {
					<code>usage_events</code> cost joined to <code>session_signals.outcome</code>; puts a price on the abandon rate.
				}
			</div>
			<div class="tabpanel instrument-solo" id="epanel-cache" role="tabpanel" aria-labelledby="etab-cache" tabindex="0" hidden>
				<div class="figures-row" id="cache-figures"></div>
				<div id="chart-cache-full"></div>
				@instrumentCaption("What prompt caching saved over time.") {
					What caching saved, priced per day and model then given a time axis; the same figure the token tiles reconcile with.
				}
			</div>
		</div>
	</section>
	<!-- 7. Subagents -->
	<section class="instrument" id="subagents" aria-labelledby="subagents-h">
		<div class="instrument-head">
			<h2 id="subagents-h">Subagents</h2>
		</div>
		<div class="panel">
			<div class="figures-row" id="subagents-figures"></div>
			<div id="chart-subagents-full"></div>
			<ul class="legend" id="subagents-legend" style="margin-top:10px;"></ul>
			<div id="chart-fanout-full" style="margin-top:20px;"></div>
			<ul class="legend" id="fanout-legend" style="margin-top:10px;"></ul>
			@instrumentCaption("How much work runs through delegation: how often the fleet spawns subagents, how wide the fan-out runs, and what share of spend rides on it.") {
				<code>parent_session_id</code> and <code>relationship_type</code> ride every session row and appear in no other aggregate. The stack below shows how wide the fan-out runs, not just how often delegation happens.
			}
		</div>
	</section>
}

// toolsInstrument is the Tools measurement panel: the reliability scatter, the category mix,
// the failure-rate trend, and the file-churn treemap, one tab each behind an "all instruments"
// overview of mini-multiples. It is shared, not fleet-only: /insights renders it inline in its
// seven-instrument strip, and the project page's Quality band reuses it verbatim (its tab ids
// and chart mounts are the contract insights.js draws into), so the two surfaces read the tool
// health identically and the markup lives in one place. The churn tab folds the file-churn
// read in with the tools, which is why the project band needs no separate churn instrument.
templ toolsInstrument() {
	<section class="instrument" id="tools" aria-labelledby="tools-h">
		<div class="instrument-head">
			<h2 id="tools-h">Tools</h2>
		</div>
		<div class="panel">
			<div role="tablist" aria-label="Tools instruments" class="tabstrip" id="tools-tabs">
				<button role="tab" id="ttab-all" aria-controls="tpanel-all" aria-selected="true" tabindex="0">All instruments</button>
				<button role="tab" id="ttab-reliability" aria-controls="tpanel-reliability" aria-selected="false" tabindex="-1">Reliability</button>
				<button role="tab" id="ttab-mix" aria-controls="tpanel-mix" aria-selected="false" tabindex="-1">Mix</button>
				<button role="tab" id="ttab-failures" aria-controls="tpanel-failures" aria-selected="false" tabindex="-1">Failures</button>
				<button role="tab" id="ttab-churn" aria-controls="tpanel-churn" aria-selected="false" tabindex="-1">Churn</button>
			</div>
			<div class="tabpanel" id="tpanel-all" role="tabpanel" aria-labelledby="ttab-all" tabindex="0">
				<div class="grid-2x2">
					<button class="mini-multiple" data-jump="tools-tabs:ttab-reliability" data-scroll="tools" id="mini-reliability"></button>
					<button class="mini-multiple" data-jump="tools-tabs:ttab-mix" data-scroll="tools" id="mini-toolmix"></button>
					<button class="mini-multiple" data-jump="tools-tabs:ttab-failures" data-scroll="tools" id="mini-failures"></button>
					<button class="mini-multiple" data-jump="tools-tabs:ttab-churn" data-scroll="tools" id="mini-churntrend"></button>
				</div>
			</div>
			<div class="tabpanel instrument-solo" id="tpanel-reliability" role="tabpanel" aria-labelledby="ttab-reliability" tabindex="0" hidden>
				<div class="overflow-x"><div id="chart-reliability" style="min-width:480px;"></div></div>
				<ul class="legend" id="reliability-legend" style="margin-top:10px;"></ul>
				@instrumentCaption("Which tools the fleet leans on most, and which ones fail most.") {
					Every tool in one frame: volume says how much you lean on it, height says how often it bites. <code>tool_calls</code> grouped by <code>tool_name</code>; error = <code>result_status='error'</code>.
				}
			</div>
			<div class="tabpanel instrument-solo" id="tpanel-mix" role="tabpanel" aria-labelledby="ttab-mix" tabindex="0" hidden>
				<div id="chart-toolmix-full"></div>
				<ul class="legend" id="toolmix-legend" style="margin-top:10px;"></ul>
				@instrumentCaption("How the balance of tool categories shifted over time.") {
					Share of each bucket's tool calls by category. Same <code>tool_calls</code> rows as the reliability map, grouped by category and drawn over time instead of collapsed to one snapshot.
				}
			</div>
			<div class="tabpanel instrument-solo" id="tpanel-failures" role="tabpanel" aria-labelledby="ttab-failures" tabindex="0" hidden>
				<div id="chart-failures-full"></div>
				@instrumentCaption("The tool failure rate over time, so a regression shows up the week it lands.") {
					Same <code>tool_calls</code> base as the scatter, drawn over time instead of collapsed to a snapshot. The fleet rate plus the window's worst offenders.
				}
			</div>
			<div class="tabpanel instrument-solo" id="tpanel-churn" role="tabpanel" aria-labelledby="ttab-churn" tabindex="0" hidden>
				<div class="figures-row" id="churn-figures"></div>
				<div id="chart-churntrend-full"></div>
				<div class="treemap-breadcrumb" id="treemap-breadcrumb" aria-label="Treemap drill path"></div>
				<div class="treemap" id="treemap"></div>
				<div class="muted small" id="churn-clip" style="margin-top:6px;"></div>
				<ul class="legend" id="churn-legend" style="margin-top:10px;"></ul>
				@instrumentCaption("Which files were edited most, and how that trended.") {
					The headline is the trend; the treemap answers which files. Drill from project to folder to file, <kbd>Escape</kbd> or a breadcrumb crumb goes back up.
				}
			</div>
		</div>
	</section>
}
