package web

import "fmt"

// PublicErrorPage keeps failures independent of account state and private data.
templ PublicErrorPage(code int, message string) {
	@publicLayout(errorTitle(code), OGMeta{}, false) {
		<div class="empty big">
			<h1>{ fmt.Sprintf("%d", code) }</h1>
			<p>{ message }</p>
			<p><a href={ Href(ctx, "/") }>Go to akari</a></p>
		</div>
	}
}
