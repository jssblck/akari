package web

// GuidePage renders one chapter of the user guide in the docs layout: a
// standalone, public document (its own head and chrome, not the signed-in app
// shell) so a logged-out reader or a coding agent can reach it. The three-column
// frame is a chapter-nav rail, the rendered prose, and an on-this-page table of
// contents with scroll-spy; guide.js drives the copy-page action, the mobile nav
// drawer, and the scroll-spy. It loads only base.css (tokens, fonts, resets) and
// guide.css, so it does not pull in the app's page stylesheets.
templ GuidePage(v GuideView) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1"/>
			<title>{ v.Title } - akari</title>
			@tzCookieScript()
			<meta name="description" content={ v.Summary }/>
			// Point agents and crawlers at the machine-readable mirrors: this page as
			// raw Markdown, and the guide-wide discovery index.
			<link rel="alternate" type="text/markdown" href={ templ.SafeURL(v.RawPath) }/>
			<link rel="alternate" type="text/plain" title="llms.txt" href="/llms.txt"/>
			<link rel="preload" href="/static/fonts/Geist-Regular.woff2" as="font" type="font/woff2" crossorigin/>
			<link rel="preload" href="/static/fonts/GeistMono-Regular.woff2" as="font" type="font/woff2" crossorigin/>
			<link rel="stylesheet" href="/static/css/base.css"/>
			<link rel="stylesheet" href="/static/guide.css"/>
			<script src="/static/guide.js" defer></script>
		</head>
		<body class="guide-body">
			<a href="#guide-main" class="guide-skip">Skip to content</a>
			@guideHeader(v)
			<div class="guide-shell">
				<div class="guide-layout">
					@guideSidebar(v)
					<main id="guide-main" class="guide-main">
						@guidePageActions(v)
						<article class="guide-prose">
							@templ.Raw(v.BodyHTML)
						</article>
						@guidePrevNext(v)
					</main>
					@guideToc(v)
				</div>
			</div>
			@guideFooter()
			// The exact Markdown source, hidden, so "Copy page" reads it from the DOM
			// with no network round-trip. A textarea decodes HTML entities on .value,
			// so the copied text is byte-for-byte the served .md.
			<textarea id="guide-page-markdown" class="guide-hidden" aria-hidden="true" readonly>{ v.RawMarkdown }</textarea>
			// Scrim for the mobile nav drawer.
			<button type="button" class="guide-scrim" data-guide-close aria-label="Close navigation"></button>
		</body>
	</html>
}

// guideHeader is the sticky top bar: the wordmark linking back to the guide
// overview, a "docs" label, a nav toggle for narrow viewports, and a corner
// action into the app.
templ guideHeader(v GuideView) {
	<header class="guide-header">
		<button type="button" class="guide-menu" data-guide-toggle aria-label="Open navigation" aria-expanded="false">
			<svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
				<path d="M2 4h12M2 8h12M2 12h12"></path>
			</svg>
		</button>
		<a class="guide-brand" href="/guide">@brandMark()</a>
		<span class="guide-header-sep"></span>
		<span class="guide-header-label">docs</span>
		<span class="spacer"></span>
		if v.LoggedIn {
			<a class="guide-header-action" href="/overview">Open app</a>
		} else {
			<a class="guide-header-action" href="/login">Log in</a>
		}
	</header>
}

// guideSidebar is the ordered chapter rail, each entry a zero-padded number and
// its label, the current chapter marked active.
templ guideSidebar(v GuideView) {
	<aside class="guide-sidebar" id="guide-sidebar">
		<nav class="guide-nav" aria-label="User guide">
			<p class="guide-nav-label">User guide</p>
			<ol class="guide-nav-list">
				for _, it := range v.Nav {
					<li>
						<a
							class={ "guide-nav-link", templ.KV("is-active", it.Active) }
							href={ templ.SafeURL(it.Route) }
							if it.Active {
								aria-current="page"
							}
						>
							<span class="guide-nav-num">{ it.Num }</span>
							<span class="guide-nav-text">{ it.Label }</span>
						</a>
					</li>
				}
			</ol>
		</nav>
	</aside>
}

// guidePageActions is the row of per-page affordances for humans and agents:
// copy the page as Markdown, open the raw .md, or edit the source on GitHub.
templ guidePageActions(v GuideView) {
	<div class="guide-actions">
		<button type="button" class="guide-action" data-copy-page>
			<svg class="guide-action-ico" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
				<rect x="5.25" y="5.25" width="8.5" height="8.5" rx="1.5" stroke="currentColor" stroke-width="1.3"></rect>
				<path d="M10.75 5.25V3.75A1.5 1.5 0 0 0 9.25 2.25H3.75A1.5 1.5 0 0 0 2.25 3.75v5.5a1.5 1.5 0 0 0 1.5 1.5h1.5" stroke="currentColor" stroke-width="1.3"></path>
			</svg>
			<span class="guide-action-text" data-copy-label>Copy page</span>
		</button>
		<a class="guide-action" href={ templ.SafeURL(v.RawPath) }>
			<svg class="guide-action-ico" width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
				<path d="M2.5 4.5v7h11v-7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"></path>
				<path d="M4.5 9.5v-3l1.75 2 1.75-2v3M11 6.5v3M9.5 8l1.5 1.5L12.5 8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path>
			</svg>
			<span class="guide-action-text">View as Markdown</span>
		</a>
		<a class="guide-action" href={ templ.SafeURL(v.GithubURL) } rel="noopener" target="_blank">
			<svg class="guide-action-ico" width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
				<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"></path>
			</svg>
			<span class="guide-action-text">Edit on GitHub</span>
		</a>
	</div>
}

// guidePrevNext is the reading-order footer: the previous chapter on the left,
// the next on the right, each a spacer at the ends of the chain so the grid
// stays balanced.
templ guidePrevNext(v GuideView) {
	<nav class="guide-prevnext" aria-label="Chapter navigation">
		if v.Prev != nil {
			<a class="guide-prevnext-link is-prev" href={ templ.SafeURL(v.Prev.Route) }>
				<span class="guide-prevnext-dir">Previous</span>
				<span class="guide-prevnext-title">{ v.Prev.Label }</span>
			</a>
		} else {
			<span class="guide-prevnext-spacer"></span>
		}
		if v.Next != nil {
			<a class="guide-prevnext-link is-next" href={ templ.SafeURL(v.Next.Route) }>
				<span class="guide-prevnext-dir">Next</span>
				<span class="guide-prevnext-title">{ v.Next.Label }</span>
			</a>
		} else {
			<span class="guide-prevnext-spacer"></span>
		}
	</nav>
}

// guideToc is the on-this-page rail of H2/H3 headings, with scroll-spy wired by
// guide.js through the data-guide-toc attribute. It is suppressed when a chapter
// has fewer than two headings, where a table of contents adds nothing.
templ guideToc(v GuideView) {
	if len(v.Toc) > 1 {
		<aside class="guide-toc" aria-label="On this page">
			<p class="guide-toc-label">On this page</p>
			<ul class="guide-toc-list">
				for _, it := range v.Toc {
					<li class={ "guide-toc-item", templ.KV("is-h3", it.Level == 3) }>
						<a class="guide-toc-link" href={ templ.SafeURL("#" + it.ID) } data-guide-toc={ it.ID }>{ it.Text }</a>
					</li>
				}
			</ul>
		</aside>
	}
}

templ guideFooter() {
	<footer class="guide-footer">
		<span>akari user guide</span>
		<span class="spacer"></span>
		<a href="/llms-full.txt">llms-full.txt</a>
		<a href="https://github.com/jssblck/akari" rel="noopener" target="_blank">Source</a>
	</footer>
}
